# ── App ──────────────────────────────────────────────────────────────────────
PROJECT_NAME="My App"
STACK_NAME=my-app
ENVIRONMENT=local

# ── Domain ───────────────────────────────────────────────────────────────────
DOMAIN=localhost
FRONTEND_HOST=http://localhost:5173
# Frontend API base URL (set on Vercel, e.g. https://api.wongweijun.me)
# VITE_API_URL=http://localhost:8000

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173"
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-me-with-a-real-secret-key
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=replace-me-with-a-strong-password

# ── Postgres ──────────────────────────────────────────────────────────────────
# For Neon / hosted Postgres, set DATABASE_URL (Render, etc.) and leave POSTGRES_* unset.
# For local Docker Compose, use POSTGRES_* below and leave DATABASE_URL unset.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Resend (transactional email — password reset, contact form) ───────────────
# When RESEND_KEY and FROM_EMAIL are set, auth/contact emails use Resend.
# SMTP below is optional fallback when Resend is not configured.
RESEND_KEY=
FROM_EMAIL="My App <noreply@example.com>"
CONTACT_EMAIL=

# ── Contact form captcha ──────────────────────────────────────────────────────
# Cloudflare Turnstile test keys always pass: site 1x00000000000000000000AA / secret 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Frontend Turnstile site key (Vite exposes VITE_* vars)
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ── Email (optional — leave blank to disable) ─────────────────────────────────
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# ── Sentry (optional — leave blank to disable) ────────────────────────────────
SENTRY_DSN=

# ── Cloudflare R2 (image uploads — avatars, post covers) ─────────────────────
# Create an R2 API token in the Cloudflare dashboard (Object Read & Write).
# R2_ACCOUNT_ID is shown on the R2 overview page.
# R2_PUBLIC_URL is your custom domain or r2.dev public bucket URL.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ── Docker image names ────────────────────────────────────────────────────────
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
